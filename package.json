{
  "name": "famtivity",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "format": "prettier --write .",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "start-clean": "react-native start --reset-cache",
    "pod-install": "cd ios && pod install && cd ..",
    "pod-clean": "cd ios && rm -rf Pods Podfile.lock && pod install --repo-update && cd ..",
    "clean-project": "rm -rf node_modules && yarn cache clean && yarn install && yarn pod-install",
    "clean-project-hard": "rm -rf node_modules yarn.lock && yarn cache clean && yarn install && yarn pod-clean && rm -rf ~/Library/Developer/Xcode/DerivedData && watchman watch-del-all 2>/dev/null || true",
    "clean-and-start": "rm -rf node_modules && yarn cache clean && yarn install && yarn pod-install && yarn start-clean",
    "export-project": "node exportComponents.js",
    "format-project": "yarn format && yarn lint",
    "test": "jest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.1",

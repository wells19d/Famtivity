{
  "name": "famtivity",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "start-clean": "react-native start --reset-cache",
    "pod-install": "cd ios && pod install && cd ..",
    "pod-clean": "cd ios && rm -rf Pods Podfile.lock && pod install --repo-update && cd ..",
    "clean-project": "rm -rf node_modules && yarn cache clean && yarn install && yarn pod-install",
    "clean-project-hard": "rm -rf node_modules yarn.lock && yarn cache clean && yarn install && yarn pod-clean",
    "clean-and-start": "rm -rf node_modules && yarn cache clean && yarn install && yarn pod-install && yarn start-clean",
    "export-project": "node exportComponents.js",
    "test": "jest"
  },
  "dependencies": {
    "react": "19.2.3",
    "react-native": "0.84.1",
    "@react-native/new-app-screen": "0.84.1",
    "react-native-safe-area-context": "^5.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
